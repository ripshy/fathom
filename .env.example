ANTHROPIC_API_KEY=
# Optional: OAuth token for the hosted Robinhood MCP connector. Without this,
# calls that request mcp_servers will fail to authenticate against Robinhood.
ROBINHOOD_MCP_TOKEN=
PORT=8787
# Log a warning when a single /api/messages call is estimated to cost more than this (USD)
COST_WARN_THRESHOLD=0.03
